{
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "extensions": [
        "streetsidesoftware.code-spell-checker"
    ],
    "features": {
    },
    "runArgs": [
        "--env-file",".devcontainer/devcontainer.env"
    ],
    "remoteEnv": {
    },
    "onCreateCommand": [
    ],
    "postCreateCommand": "make 2>&1 | tee /tmp/make_build.log && make install SHELL='/bin/bash -x' 2>&1 | tee /tmp/make_install.log",
    "portsAttributes": {
        "2159": {
            "label": "gdb"
        },
        "6379": {
            "label": "redis"
        }
    }
}
