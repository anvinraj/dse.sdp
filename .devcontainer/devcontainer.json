{
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "extensions": [
        "streetsidesoftware.code-spell-checker",
        "./lsp/out/bin/dse.vsix"
    ],
    "features": {
    },
    "runArgs": [
        "--env-file",".devcontainer/devcontainer.env"
    ],
    "remoteEnv": {
    },
    "onCreateCommand": [
    ],
    "postCreateCommand": {
     "SDP build": "make 2>&1 | tee /tmp/make_build.log",
     "SDP install": "make install SHELL='/bin/bash -x' 2>&1 | tee /tmp/make_install.log"
     },
    "portsAttributes": {
        "2159": {
            "label": "gdb"
        },
        "6379": {
            "label": "redis"
        }
    }
}
